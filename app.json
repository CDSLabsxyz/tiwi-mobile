{
  "expo": {
    "name": "Tiwi Protocol",
    "slug": "tiwi-mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/tiwi-logo.svg",
    "scheme": "tiwiprotocol",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#010501",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#010501",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "app.tiwiprotocol.xyz",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/full logo.svg",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#010501",
          "dark": {
            "backgroundColor": "#010501"
          }
        }
      ],
      "expo-secure-store",
      "expo-audio",
      "expo-video",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0d2d610c-399b-4ed0-998e-bfff64e01fd2"
      }
    }
  }
}
