{
  "expo": {
    "name": "TIWI Protocol",
    "slug": "tiwi-mobile-app",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/logo/image.png",
    "scheme": "tiwiprotocol",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#010501",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.tiwiprotocol.xyz",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification", "fetch", "processing"],
        "NSCameraUsageDescription": "Used to scan QR codes and barcodes."
      }
    },
    "android": {
      "icon": "./assets/logo/image.png",
      "adaptiveIcon": {
        "backgroundColor": "#010501",
        "foregroundImage": "./assets/logo/image.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "app.tiwiprotocol.xyz",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.REQUEST_INSTALL_PACKAGES",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/logo/image.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo/image.png",
          "imageWidth": 1,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/logo/notifications.png",
          "color": "#B1F128",
          "defaultChannel": "default",
          "sounds": []
        }
      ],
      "expo-audio",
      "expo-video",
      "expo-asset",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera to scan QR codes and barcodes.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "minSdkVersion": 24,
            "kotlinVersion": "2.1.20"
          }
        }
      ],
      "./plugins/withFastPbkdf2Fix.js"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8548b9d9-c2bc-43ad-8f31-a7dedd0f6b58"
      }
    },
    "owner": "gcodes",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/8548b9d9-c2bc-43ad-8f31-a7dedd0f6b58"
    }
  }
}
